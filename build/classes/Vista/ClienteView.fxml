<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    ClienteView.fxml
    Ubicación: src/Vista/ClienteView.fxml
    Controlador: Controlador.ClienteController
    Requerimientos: CUS-1
      R1  Registrar cliente
      R2  Editar cliente
      R3  Eliminar cliente
      R4  Buscar cliente
      R5  Listar clientes
      R6  Registrar dirección cliente
      R7  Asignar ubicación
-->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.ClienteController"
      spacing="16"
      style="-fx-background-color: #F0F4F8;"
      HBox.hgrow="ALWAYS">

    <!-- ══════════════════════════════════════
         PANEL IZQUIERDO: tabla + buscador
    ══════════════════════════════════════ -->
    <VBox spacing="12" HBox.hgrow="ALWAYS">

        <!-- Barra superior: búsqueda + botones -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: white;
                     -fx-padding: 14 16 14 16;
                     -fx-background-radius: 10;
                     ">

            <!-- Buscador (R4) -->
            <TextField fx:id="txtBuscar"
                       promptText="🔍  Buscar por nombre o DNI..."
                       prefWidth="280"
                       styleClass="text-field"
                       onKeyReleased="#buscarCliente"/>

            <!-- Filtro por estado -->
            <ComboBox fx:id="cmbFiltroEstado"
                      promptText="Todos"
                      prefWidth="130"
                      styleClass="combo-box"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <!-- Botón nuevo (R1) -->
            <Button fx:id="btnNuevo"
                    text="+ Nuevo cliente"
                    styleClass="btn-primary"
                    onAction="#nuevoCliente"/>
        </HBox>

        <!-- Tabla de clientes (R5) -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     ">

            <TableView fx:id="tblClientes"
                       VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       onMouseClicked="#seleccionarCliente">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="55"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNombre"   text="Nombre"    prefWidth="160"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDni"      text="DNI"       prefWidth="90"   style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono"  prefWidth="110"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEmail"    text="Correo"    prefWidth="180"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="200" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEstado"   text="Estado"    prefWidth="90"  style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="No hay clientes registrados"
                           style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

            <!-- Pie de tabla: contador -->
            <HBox style="-fx-padding: 8 16 8 16; -fx-border-color: #F0F4F8; -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblContador"
                       text="0 clientes registrados"
                       style="-fx-text-fill: #5A6A7A; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ══════════════════════════════════════
         PANEL DERECHO: formulario
    ══════════════════════════════════════ -->
    <VBox prefWidth="320" spacing="0"
          style="-fx-background-color: white;
                 -fx-background-radius: 10;
                 ">

        <!-- Cabecera del formulario -->
        <HBox style="-fx-padding: 16 20 16 20;
                     -fx-border-color: transparent transparent #F0F4F8 transparent;
                     -fx-border-width: 1;"
              alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="lblTituloForm"
                   text="Nuevo cliente"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"
                   HBox.hgrow="ALWAYS"/>
            <!-- Botón limpiar -->
            <Button text="✕"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0ADB8;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"
                    onAction="#limpiarFormulario"/>
        </HBox>

        <!-- Campos del formulario -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox spacing="14" style="-fx-padding: 20 20 20 20;">

                <!-- DNI -->
                

                <VBox spacing="5">
                    <Label text="NOMBRES" styleClass="label-field"/>
                    <TextField fx:id="txtNombres" promptText="Ej: Juan Carlos"
                               styleClass="text-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="APELLIDOS" styleClass="label-field"/>
                    <TextField fx:id="txtApellidos" promptText="Ej: García López"
                               styleClass="text-field"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="DNI / RUC" styleClass="label-field"/>
                    <TextField fx:id="txtDni"
                               promptText="Ej: 12345678"
                               styleClass="text-field"/>
                </VBox>
                <!-- Teléfono -->
                <VBox spacing="5">
                    <Label text="TELÉFONO" styleClass="label-field"/>
                    <TextField fx:id="txtTelefono"
                               promptText="Ej: 999 888 777"
                               styleClass="text-field"/>
                </VBox>

                <!-- Correo -->
                <VBox spacing="5">
                    <Label text="CORREO ELECTRÓNICO" styleClass="label-field"/>
                    <TextField fx:id="txtEmail"
                               promptText="ejemplo@correo.com"
                               styleClass="text-field"/>
                </VBox>

                <Separator/>

                <!-- Sección dirección (R6) -->
                <Label text="DIRECCIÓN" styleClass="label-section"/>

                <!-- Dirección -->
                <VBox spacing="5">
                    <Label text="CALLE / AV." styleClass="label-field"/>
                    <TextField fx:id="txtDireccion"
                               promptText="Ej: Av. Lima 123"
                               styleClass="text-field"/>
                </VBox>

                <!-- Distrito -->

                <!-- Zona (R7 Asignar ubicación) -->
                <VBox spacing="5">
                    <Label text="DISTRITO" styleClass="label-field"/>
                    <ComboBox fx:id="cmbDistrito" promptText="Seleccionar distrito"
                              prefWidth="1000" styleClass="combo-box"/>
                </VBox>

                <!-- Referencia -->
                <VBox spacing="5">
                    <Label text="REFERENCIA" styleClass="label-field"/>
                    <TextArea fx:id="txtReferencia"
                              promptText="Referencia de la ubicación..."
                              prefRowCount="2"
                              styleClass="text-field"
                              wrapText="true"/>
                </VBox>

                <Separator/>

                <!-- Estado -->

                <!-- Mensaje de validación -->
                <Label fx:id="lblMensaje"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 12px;"/>

            </VBox>
        </ScrollPane>

        <!-- Botones de acción -->
        <VBox spacing="8" style="-fx-padding: 16 20 16 20;
                                  -fx-border-color: #F0F4F8 transparent transparent transparent;
                                  -fx-border-width: 1;">
            <!-- Guardar (R1 / R2) -->
            <Button fx:id="btnGuardar"
                    text="Guardar cliente"
                    maxWidth="1000"
                    prefHeight="40"
                    styleClass="btn-primary"
                    onAction="#guardarCliente"/>

            <HBox spacing="8">
                <!-- Eliminar (R3) -->
                <Button fx:id="btnEliminar"
                        text="Desactivar"
                        HBox.hgrow="ALWAYS"
                        maxWidth="1000"
                        prefHeight="36"
                        styleClass="btn-danger"
                        disable="true"
                        onAction="#eliminarCliente"/>
                <!-- Cancelar -->
                <Button fx:id="btnCancelar"
                        text="Cancelar"
                        HBox.hgrow="ALWAYS"
                        maxWidth="1000"
                        prefHeight="36"
                        styleClass="btn-secondary"
                        onAction="#limpiarFormulario"/>
            </HBox>
        </VBox>
    </VBox>

</HBox>
