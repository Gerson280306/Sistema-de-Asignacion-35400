<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    LoginView.fxml
    Ubicación: src/Vista/LoginView.fxml
    Controlador: Controlador.LoginController
    Requerimientos: CUS-8 (R48 Validar datos, R49 Acceso gerente)
-->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.LoginController"
      prefWidth="860" prefHeight="540"
      stylesheets="@styles.css">

    <!-- Panel izquierdo: marca -->
    <StackPane prefWidth="400" prefHeight="540">

        <Pane style="-fx-background-color: #0D2137;"/>

        <Pane prefWidth="260" prefHeight="260"
              style="-fx-background-color: #1565C0; -fx-background-radius: 130; -fx-opacity: 0.18;"
              StackPane.alignment="BOTTOM_LEFT"
              translateX="-60" translateY="60"/>

        <Pane prefWidth="280" prefHeight="280"
              style="-fx-background-color: #1976D2; -fx-background-radius: 140; -fx-opacity: 0.12;"
              StackPane.alignment="TOP_RIGHT"
              translateX="80" translateY="-80"/>

        <VBox alignment="CENTER" spacing="18" style="-fx-padding: 48 40 48 40;">

            <StackPane>
                <Pane prefWidth="72" prefHeight="72"
                      style="-fx-background-color: #1565C0;
                             -fx-background-radius: 18;
                             "/>
                <Label text="SBR Telecomunicaciones"
                       style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            </StackPane>

            <VBox alignment="CENTER" spacing="6">
                <Label text="Sistema de Asignación"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Gestión inteligente de técnicos"
                       style="-fx-text-fill: #6B8CAE; -fx-font-size: 13px;"/>
            </VBox>

            <Separator prefWidth="200" style="-fx-padding: 8 0 8 0;"/>

            <VBox spacing="12" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="Asignación automática de solicitudes"
                           style="-fx-text-fill: #A8C0D4; -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="Seguimiento en tiempo real"
                           style="-fx-text-fill: #A8C0D4; -fx-font-size: 12px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label text="Reportes y métricas de rendimiento"
                           style="-fx-text-fill: #A8C0D4; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <!-- Panel derecho: formulario -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: #F0F4F8;">
        <VBox alignment="CENTER" spacing="0"
              style="-fx-padding: 0 60 0 60; -fx-max-width: 360;">

            <VBox spacing="6" style="-fx-padding: 0 0 32 0;">
                <Label text="Bienvenido" styleClass="label-title"/>
                <Label text="Ingresa tus credenciales para continuar"
                       styleClass="label-subtitle"/>
            </VBox>

            <VBox spacing="6" style="-fx-padding: 0 0 16 0;">
                <Label text="USUARIO" styleClass="label-field"/>
                <TextField fx:id="txtUsuario"
                           promptText="Ingresa tu usuario"
                           maxWidth="320"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="6" style="-fx-padding: 0 0 8 0;">
                <Label text="CONTRASEÑA" styleClass="label-field"/>
                <PasswordField fx:id="txtPassword"
                               promptText="••••••••"
                               maxWidth="320"
                               styleClass="password-field"/>
            </VBox>

            <Label fx:id="lblError"
                   text=""
                   style="-fx-text-fill: #C62828; -fx-font-size: 12px; -fx-padding: 4 0 12 0;"
                   wrapText="true"
                   maxWidth="320"/>

            <Button fx:id="btnIngresar"
                    text="Ingresar al sistema"
                    maxWidth="320"
                    prefHeight="42"
                    styleClass="btn-primary"
                    onAction="#handleLogin"/>

            <HBox alignment="CENTER" spacing="10"
                  style="-fx-padding: 20 0 0 0;">
                <Label text="v1.0.0 — Sistema de Asignación"
                       style="-fx-text-fill: #A0ADB8; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </StackPane>
</HBox>
