<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.ReporteController"
      spacing="16"
      style="-fx-background-color: #F0F4F8; -fx-padding: 0;"
      VBox.vgrow="ALWAYS">

    <!-- Filtros -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 14 16 14 16;
                 -fx-background-radius: 10;
                 ">

        <ComboBox fx:id="cmbTipoReporte"
                  promptText="Tipo de reporte"
                  prefWidth="200"
                  onAction="#cambiarTipoReporte"/>

        <DatePicker fx:id="dpDesde" promptText="Desde" prefWidth="130" onAction="#generarReporte"/>
        <DatePicker fx:id="dpHasta" promptText="Hasta" prefWidth="130" onAction="#generarReporte"/>

        <ComboBox fx:id="cmbFiltroTecnico"
                  promptText="Técnico (opcional)"
                  prefWidth="160"/>

        <Button text="Generar"
                style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-padding: 9 18 9 18; -fx-background-radius: 6; -fx-cursor: hand;"
                onAction="#generarReporte"/>

        <Button text="Limpiar"
                style="-fx-background-color: transparent; -fx-border-color: #1565C0;
                       -fx-border-width: 1.5; -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-text-fill: #1565C0; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                onAction="#limpiar"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Button text="Exportar Excel"
                style="-fx-background-color: transparent; -fx-border-color: #1565C0;
                       -fx-border-width: 1.5; -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-text-fill: #1565C0; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                onAction="#exportarExcel"/>

        <Button text="Exportar PDF"
                style="-fx-background-color: transparent; -fx-border-color: #1565C0;
                       -fx-border-width: 1.5; -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-text-fill: #1565C0; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                onAction="#exportarPdf"/>
    </HBox>

    <!-- KPIs -->
    <HBox spacing="16">
        <VBox HBox.hgrow="ALWAYS" spacing="6"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16;
                     ">
            <Label text="TOTAL SOLICITUDES"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3A4A5A;"/>
            <Label fx:id="kpiTotalSolicitudes" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
            <Label text="En el período"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="6"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16;
                     ">
            <Label text="ATENDIDAS"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3A4A5A;"/>
            <Label fx:id="kpiAtendidas" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Label text="Completadas"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="6"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16;
                     ">
            <Label text="PENDIENTES"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3A4A5A;"/>
            <Label fx:id="kpiPendientes" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F57F17;"/>
            <Label text="Sin completar"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="6"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16;
                     ">
            <Label text="TIEMPO PROMEDIO"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3A4A5A;"/>
            <Label fx:id="kpiTiempoPromedio" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
            <Label text="Horas por atención"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" spacing="6"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16;
                     ">
            <Label text="EFICIENCIA"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #3A4A5A;"/>
            <Label fx:id="kpiEficiencia" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
            <Label text="Completadas"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"/>
        </VBox>
    </HBox>

    <!-- Tabla -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 10;
                 ">

        <HBox style="-fx-padding: 14 16 14 16;
                     -fx-border-color: transparent transparent #F0F4F8 transparent;
                     -fx-border-width: 1;" alignment="CENTER_LEFT">
            <Label fx:id="lblTituloTabla" text="Resultados del reporte"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"
                   HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblContador" text="0 registros"
                   style="-fx-text-fill: #5A6A7A; -fx-font-size: 12px;"/>
        </HBox>

        <TableView fx:id="tblReporte" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCol1" text="Técnico"     prefWidth="180"/>
                <TableColumn fx:id="colCol2" text="Atendidas"   prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCol3" text="Pendientes"  prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCol4" text="Canceladas"  prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCol5" text="T. Promedio" prefWidth="110" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCol6" text="Eficiencia"  prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCol7" text="Zona"        prefWidth="110"/>
            </columns>
            <placeholder>
                <Label text="Selecciona un tipo de reporte y presiona Generar"
                       style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
