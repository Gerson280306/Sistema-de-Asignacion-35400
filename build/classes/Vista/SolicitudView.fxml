<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.SolicitudController"
      spacing="16"
      style="-fx-background-color: #F0F4F8;"
      HBox.hgrow="ALWAYS">

    <!-- PANEL IZQUIERDO: filtros + tabla -->
    <VBox spacing="12" HBox.hgrow="ALWAYS">

        <!-- Barra de filtros: solo búsqueda de texto -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: white;
                     -fx-padding: 14 16 14 16;
                     -fx-background-radius: 10;">

            <TextField fx:id="txtBuscar"
                       promptText="🔍  Buscar solicitud o cliente..."
                       prefWidth="280"
                       styleClass="text-field"
                       onKeyReleased="#buscarSolicitud"/>

            <ComboBox fx:id="cmbFiltroEstado"
                      promptText="Todos"
                      prefWidth="160"
                      styleClass="combo-box"
                      onAction="#buscarSolicitud"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button fx:id="btnNueva"
                    text="+ Nueva solicitud"
                    styleClass="btn-primary"
                    onAction="#nuevaSolicitud"/>
        </HBox>

        <!-- Tabla de solicitudes -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10;">
            <TableView fx:id="tblSolicitudes"
                       VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       onMouseClicked="#seleccionarSolicitud">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"        prefWidth="55"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colCliente"   text="Cliente"   prefWidth="160" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colFecha"     text="Fecha"     prefWidth="95"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colHora"      text="Hora"      prefWidth="70"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colTipo"      text="Tipo"      prefWidth="160" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colPrioridad" text="Prioridad" prefWidth="90"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="110" style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="No hay solicitudes"
                           style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
            <HBox style="-fx-padding: 8 16 8 16;">
                <Label fx:id="lblContador"
                       text="0 solicitudes"
                       style="-fx-text-fill: #5A6A7A; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- PANEL DERECHO: formulario -->
    <VBox prefWidth="340" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 10;">

        <!-- Cabecera -->
        <HBox style="-fx-padding: 16 20 16 20;
                     -fx-border-color: transparent transparent #F0F4F8 transparent;
                     -fx-border-width: 1;"
              alignment="CENTER_LEFT">
            <Label fx:id="lblTituloForm"
                   text="Nueva solicitud"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"
                   HBox.hgrow="ALWAYS"/>
            <Button text="✕"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0ADB8;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"
                    onAction="#limpiarFormulario"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox spacing="14" style="-fx-padding: 20 20 20 20;">

                <!-- Cliente -->
                <VBox spacing="5">
                    <Label text="CLIENTE" styleClass="label-field"/>
                    <ComboBox fx:id="cmbCliente"
                              promptText="Seleccionar cliente"
                              prefWidth="1000"
                              styleClass="combo-box"/>
                </VBox>

                <!-- Fecha -->
                <VBox spacing="5">
                    <Label text="FECHA DE SOLICITUD" styleClass="label-field"/>
                    <DatePicker fx:id="dpFechaSolicitud" prefWidth="1000"/>
                </VBox>

                <!-- Hora -->
                <VBox spacing="5">
                    <Label text="HORA DE ATENCIÓN" styleClass="label-field"/>
                    <HBox spacing="0" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-border-color: #DDE3EA;
                                 -fx-border-width: 1.5; -fx-border-radius: 6;
                                 -fx-background-radius: 6; -fx-padding: 6 10 6 10;">
                        <Label text="🕐" style="-fx-font-size: 15px; -fx-padding: 0 8 0 0;"/>
                        <TextField fx:id="txtHoraHH" promptText="08" prefWidth="42"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-font-size: 15px; -fx-font-weight: bold;
                                          -fx-text-fill: #1A2332; -fx-alignment: CENTER; -fx-padding: 0;"/>
                        <Label text=":" style="-fx-font-size: 17px; -fx-font-weight: bold;
                                              -fx-text-fill: #1A2332; -fx-padding: 0 2 2 2;"/>
                        <TextField fx:id="txtHoraMM" promptText="00" prefWidth="42"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-font-size: 15px; -fx-font-weight: bold;
                                          -fx-text-fill: #1A2332; -fx-alignment: CENTER; -fx-padding: 0;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="08:00" onAction="#setHora0800"
                                style="-fx-background-color: #EBF3FF; -fx-text-fill: #1565C0;
                                       -fx-font-size: 11px; -fx-padding: 4 8 4 8;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-border-color: transparent;"/>
                        <Button text="12:00" onAction="#setHora1200"
                                style="-fx-background-color: #EBF3FF; -fx-text-fill: #1565C0;
                                       -fx-font-size: 11px; -fx-padding: 4 8 4 8;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-border-color: transparent;"/>
                        <Button text="17:00" onAction="#setHora1700"
                                style="-fx-background-color: #EBF3FF; -fx-text-fill: #1565C0;
                                       -fx-font-size: 11px; -fx-padding: 4 8 4 8;
                                       -fx-background-radius: 4; -fx-cursor: hand; -fx-border-color: transparent;"/>
                    </HBox>
                    <Label text="Horario de atención: 08:00 — 17:00"
                           style="-fx-font-size: 11px; -fx-text-fill: #A0ADB8;"/>
                </VBox>

                <!-- Tipo -->
                <VBox spacing="5">
                    <Label text="TIPO / CLASIFICACIÓN" styleClass="label-field"/>
                    <ComboBox fx:id="cmbTipo"
                              promptText="Seleccionar tipo"
                              prefWidth="1000"
                              styleClass="combo-box"/>
                </VBox>

                <!-- Prioridad -->
                <VBox spacing="5">
                    <Label text="PRIORIDAD" styleClass="label-field"/>
                    <ComboBox fx:id="cmbPrioridad"
                              prefWidth="1000"
                              styleClass="combo-box"/>
                </VBox>

                <!-- Descripción -->
                <VBox spacing="5">
                    <Label text="DESCRIPCIÓN DEL PROBLEMA" styleClass="label-field"/>
                    <TextArea fx:id="txtDescripcion"
                              promptText="Describe el problema o requerimiento..."
                              prefRowCount="3"
                              styleClass="text-field"
                              wrapText="true"/>
                </VBox>

                <Separator/>

                <!-- Observaciones -->
                <VBox spacing="5">
                    <Label text="OBSERVACIONES" styleClass="label-field"/>
                    <TextArea fx:id="txtObservaciones"
                              promptText="Observaciones adicionales..."
                              prefRowCount="2"
                              styleClass="text-field"
                              wrapText="true"/>
                </VBox>

                <!-- Mensaje -->
                <Label fx:id="lblMensaje"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 12px;"/>

            </VBox>
        </ScrollPane>

        <!-- Botones -->
        <VBox spacing="8" style="-fx-padding: 16 20 16 20;
                                  -fx-border-color: #F0F4F8 transparent transparent transparent;
                                  -fx-border-width: 1;">
            <Button fx:id="btnGuardar"
                    text="Guardar solicitud"
                    maxWidth="1000"
                    prefHeight="40"
                    styleClass="btn-primary"
                    onAction="#guardarSolicitud"/>
            <HBox spacing="8">
                <Button fx:id="btnCancelarSolicitud"
                        text="Cancelar sol."
                        HBox.hgrow="ALWAYS"
                        maxWidth="1000"
                        prefHeight="36"
                        styleClass="btn-danger"
                        disable="true"
                        onAction="#cancelarSolicitud"/>
            </HBox>
        </VBox>
    </VBox>

</HBox>
