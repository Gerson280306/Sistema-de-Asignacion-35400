<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    AdminCuentasView.fxml
    Controlador: Controlador.AdminCuentasController
    Estilo idéntico a ClienteView: tabla izquierda + formulario fijo derecha.
-->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.AdminCuentasController"
      spacing="16"
      style="-fx-background-color: #F0F4F8;"
      HBox.hgrow="ALWAYS">

    <!-- ══════════════════════════════════════
         PANEL IZQUIERDO: buscador + tabla
    ══════════════════════════════════════ -->
    <VBox spacing="12" HBox.hgrow="ALWAYS">

        <!-- Barra superior -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: white;
                     -fx-padding: 14 16 14 16;
                     -fx-background-radius: 10;">

            <TextField fx:id="txtBuscar"
                       promptText="🔍  Buscar por usuario o nombre..."
                       prefWidth="280"
                       styleClass="text-field"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="+ Nueva cuenta"
                    styleClass="btn-primary"
                    onAction="#nuevaCuenta"/>
        </HBox>

        <!-- Tabla -->
        <VBox VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 10;">

            <TableView fx:id="tblCuentas"
                       VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       onMouseClicked="#seleccionarCuenta">
                <columns>
                    <TableColumn fx:id="colId"            text="ID"             prefWidth="50"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colUsername"      text="Usuario"         prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colNombre"        text="Nombre completo" prefWidth="190" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEmail"         text="Email"           prefWidth="170" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEstado"        text="Estado"          prefWidth="80"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colUltimoAcceso"  text="Último acceso"   prefWidth="130" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colFechaCreacion" text="Creado"          prefWidth="90"  style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="No hay cuentas de gestores registradas."
                           style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

            <HBox style="-fx-padding: 8 16 8 16; -fx-border-color: #F0F4F8; -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblContador"
                       text="0 cuentas registradas"
                       style="-fx-text-fill: #5A6A7A; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ══════════════════════════════════════
         PANEL DERECHO: formulario siempre visible
    ══════════════════════════════════════ -->
    <VBox prefWidth="320" spacing="0"
          style="-fx-background-color: white; -fx-background-radius: 10;">

        <!-- Cabecera -->
        <HBox style="-fx-padding: 16 20 16 20;
                     -fx-border-color: transparent transparent #F0F4F8 transparent;
                     -fx-border-width: 1;"
              alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="lblTituloForm"
                   text="Nueva cuenta"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"
                   HBox.hgrow="ALWAYS"/>
            <Button text="✕"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0ADB8;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"
                    onAction="#limpiarFormulario"/>
        </HBox>

        <!-- Campos -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox spacing="14" style="-fx-padding: 20 20 20 20;">

                <VBox spacing="5">
                    <Label text="USUARIO" styleClass="label-field"/>
                    <TextField fx:id="txtFUsername" promptText="Nombre de usuario"
                               styleClass="text-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="NOMBRE COMPLETO" styleClass="label-field"/>
                    <TextField fx:id="txtFNombre" promptText="Nombre y apellidos"
                               styleClass="text-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="EMAIL" styleClass="label-field"/>
                    <TextField fx:id="txtFEmail" promptText="correo@ejemplo.com"
                               styleClass="text-field"/>
                </VBox>

                <Separator/>

                <VBox spacing="5">
                    <Label text="CONTRASEÑA" styleClass="label-field"/>
                    <PasswordField fx:id="txtFPassword" promptText="Mínimo 6 caracteres"
                                   styleClass="text-field"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="CONFIRMAR CONTRASEÑA" styleClass="label-field"/>
                    <PasswordField fx:id="txtFPasswordConf" promptText="Repite la contraseña"
                                   styleClass="text-field"/>
                </VBox>

                <Label fx:id="lblFormError" text=""
                       style="-fx-text-fill: #C62828; -fx-font-size: 12px;"
                       wrapText="true"/>

            </VBox>
        </ScrollPane>

        <!-- Botones de acción -->
        <VBox spacing="8" style="-fx-padding: 16 20 16 20;
                                  -fx-border-color: #F0F4F8 transparent transparent transparent;
                                  -fx-border-width: 1;">
            <Button fx:id="btnGuardar"
                    text="Guardar cuenta"
                    maxWidth="1000"
                    prefHeight="40"
                    styleClass="btn-primary"
                    onAction="#guardarCuenta"/>
            <HBox spacing="8">
                <Button fx:id="btnToggleEstado"
                        text="Desactivar"
                        HBox.hgrow="ALWAYS"
                        maxWidth="1000"
                        prefHeight="36"
                        styleClass="btn-danger"
                        disable="true"
                        onAction="#toggleEstado"/>
                <Button text="Cancelar"
                        HBox.hgrow="ALWAYS"
                        maxWidth="1000"
                        prefHeight="36"
                        styleClass="btn-secondary"
                        onAction="#limpiarFormulario"/>
            </HBox>
        </VBox>

    </VBox>

</HBox>
