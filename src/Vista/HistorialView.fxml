<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    HistorialView.fxml
    Ubicación: src/Vista/HistorialView.fxml
    Controlador: Controlador.HistorialController
    Requerimientos: CUS-6
      R41 Ver historial de asignaciones
      R42 Filtrar por técnico
      R43 Filtrar por cliente
      R44 Filtrar por fecha
      R45 Ver detalle de atención
      R46 Exportar historial
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controlador.HistorialController"
      spacing="16"
      style="-fx-background-color: #F0F4F8;"
      VBox.vgrow="ALWAYS">

    <!-- Filtros (R42, R43, R44) -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 14 16 14 16;
                 -fx-background-radius: 10;
                 ">

        <TextField fx:id="txtBuscar"
                   promptText="🔍  Buscar..."
                   prefWidth="200" styleClass="text-field"
                   onKeyReleased="#buscar"/>

        <!-- Filtro por técnico (R42) -->
        <ComboBox fx:id="cmbFiltroTecnico"
                  promptText="Técnico" prefWidth="150"
                  styleClass="combo-box" onAction="#filtrar"/>

        <!-- Filtro por cliente (R43) -->
        <ComboBox fx:id="cmbFiltroCliente"
                  promptText="Cliente" prefWidth="150"
                  styleClass="combo-box" onAction="#filtrar"/>

        <!-- Filtro por fecha (R44) -->
        <DatePicker fx:id="dpDesde" promptText="Desde" prefWidth="125" onAction="#filtrar"/>
        <DatePicker fx:id="dpHasta" promptText="Hasta" prefWidth="125" onAction="#filtrar"/>

        <Button text="Limpiar" styleClass="btn-secondary" onAction="#limpiarFiltros"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Exportar (R46) -->
        <Button fx:id="btnExportar"
                text="⬇ Exportar Excel"
                styleClass="btn-secondary"
                onAction="#exportarHistorial"/>
    </HBox>

    <!-- Cuerpo -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Tabla de historial (R41) -->
        <VBox HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     ">

            <HBox style="-fx-padding: 14 16 14 16;
                         -fx-border-color: transparent transparent #F0F4F8 transparent;
                         -fx-border-width: 1;" alignment="CENTER_LEFT">
                <Label text="Historial de asignaciones"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"
                       HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTotalRegistros"
                       text="0 registros"
                       style="-fx-text-fill: #5A6A7A; -fx-font-size: 12px;"/>
            </HBox>

            <TableView fx:id="tblHistorial"
                       VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       onMouseClicked="#verDetalle">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"          prefWidth="55"  style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colFechaAsig"   text="Asignado"    prefWidth="100"/>
                    <TableColumn fx:id="colFechaAten"   text="Atendido"    prefWidth="100"/>
                    <TableColumn fx:id="colCliente"     text="Cliente"     prefWidth="160"/>
                    <TableColumn fx:id="colTecnico"     text="Técnico"     prefWidth="150"/>
                    <TableColumn fx:id="colTipo"        text="Tipo"        prefWidth="110"/>
                    <TableColumn fx:id="colEstado"      text="Estado"      prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDuracion"    text="Duración"    prefWidth="90"  style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="No hay registros en el historial"
                           style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Panel de detalle (R45) -->
        <VBox prefWidth="320"
              style="-fx-background-color: white; -fx-background-radius: 10;
                     ">

            <HBox style="-fx-padding: 14 16 14 16;
                         -fx-border-color: transparent transparent #F0F4F8 transparent;
                         -fx-border-width: 1;">
                <Label text="Detalle de atención"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A2332;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox spacing="14" style="-fx-padding: 16 20 16 20;">

                    <!-- Sin selección -->
                    <Label fx:id="lblSinSeleccion"
                           text="Selecciona un registro de la tabla para ver el detalle."
                           style="-fx-text-fill: #A0ADB8; -fx-font-size: 13px;"
                           wrapText="true"/>

                    <!-- Detalle (se muestra al seleccionar) -->
                    <VBox fx:id="panelDetalle" spacing="10" visible="false" managed="false">

                        <VBox spacing="4"
                              style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                     -fx-padding: 12;" >
                            <Label text="CLIENTE" styleClass="label-field"/>
                            <Label fx:id="detCliente" text="—"
                                   style="-fx-font-size: 13px; -fx-text-fill: #1A2332;"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="4"
                              style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                     -fx-padding: 12;">
                            <Label text="TÉCNICO" styleClass="label-field"/>
                            <Label fx:id="detTecnico" text="—"
                                   style="-fx-font-size: 13px; -fx-text-fill: #1A2332;"/>
                        </VBox>

                        <HBox spacing="8">
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                         -fx-padding: 12;">
                                <Label text="TIPO" styleClass="label-field"/>
                                <Label fx:id="detTipo" text="—"
                                       style="-fx-font-size: 13px; -fx-text-fill: #1A2332;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                         -fx-padding: 12;">
                                <Label text="ESTADO" styleClass="label-field"/>
                                <Label fx:id="detEstado" text="—"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="8">
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                         -fx-padding: 12;">
                                <Label text="ASIGNADO" styleClass="label-field"/>
                                <Label fx:id="detFechaAsig" text="—"
                                       style="-fx-font-size: 12px; -fx-text-fill: #1A2332;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                         -fx-padding: 12;">
                                <Label text="ATENDIDO" styleClass="label-field"/>
                                <Label fx:id="detFechaAten" text="—"
                                       style="-fx-font-size: 12px; -fx-text-fill: #1A2332;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="4"
                              style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                     -fx-padding: 12;">
                            <Label text="DESCRIPCIÓN" styleClass="label-field"/>
                            <Label fx:id="detDescripcion" text="—"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="4"
                              style="-fx-background-color: #F5F8FC; -fx-background-radius: 8;
                                     -fx-padding: 12;">
                            <Label text="NOTAS DE CIERRE" styleClass="label-field"/>
                            <Label fx:id="detNotas" text="—"
                                   style="-fx-font-size: 12px; -fx-text-fill: #5A6A7A;"
                                   wrapText="true"/>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
